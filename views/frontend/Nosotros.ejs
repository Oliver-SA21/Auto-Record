                <p class="text-slate-600 max-w-3xl mx-auto">
                    Estas son las personas que colaboran en el desarrollo, organización y presentación de Auto-Record.
                </p>
            </div>

            <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6">
                <div class="bg-white rounded-3xl shadow-lg border border-blue-100 p-6 text-center">
