<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auto-Record - Iniciar sesión</title>
    <link rel="icon" type="image/x-icon" href="/img/google.ico">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex items-center justify-center px-4 py-10">

    <div class="w-full max-w-6xl bg-white rounded-[2.5rem] shadow-2xl border border-blue-100 p-6 md:p-10">
        <div class="grid lg:grid-cols-2 gap-8 items-start">

            <!-- COLUMNA IZQUIERDA -->
            <div class="bg-white rounded-3xl p-4 md:p-8">
                <div class="text-center mb-8">
                    <div class="flex justify-center mb-4">
                        <img src="/img/LogoProyecto.jpeg" alt="Logo Auto-Record" class="w-20 h-20 rounded-full object-cover border-2 border-blue-100 shadow-md">
                    </div>

                    <h1 class="text-4xl font-extrabold text-slate-900 mb-3">Bienvenido</h1>
                    <p class="text-slate-600">
                        Inicia sesión para continuar como
                        <span class="font-bold text-blue-700 capitalize"><%= rol %></span>
                    </p>
                </div>

                <form id="emailLoginForm" class="space-y-5">
                    <div>
                        <label for="correoEmail" class="block text-sm font-semibold text-slate-700 mb-2">
                            Correo electrónico
                        </label>
                        <input
                            type="email"
                            id="correoEmail"
                            name="correo"
                            placeholder="Ingresa tu correo"
                            class="w-full rounded-2xl border border-blue-200 bg-slate-50 px-4 py-4 focus:outline-none focus:ring-2 focus:ring-blue-400"
                        >
                    </div>

                    <div>
                        <label for="passwordEmail" class="block text-sm font-semibold text-slate-700 mb-2">
                            Contraseña
                        </label>
                        <input
                            type="password"
                            id="passwordEmail"
                            name="password"
                            placeholder="Ingresa tu contraseña"
                            class="w-full rounded-2xl border border-blue-200 bg-slate-50 px-4 py-4 focus:outline-none focus:ring-2 focus:ring-blue-400"
                        >
                    </div>

                    <p id="errorMsgEmail" class="hidden text-sm font-semibold" style="color:#941F4E;"></p>

                    <button
                        type="submit"
                        class="w-full bg-blue-700 hover:bg-blue-800 text-white font-semibold px-6 py-4 rounded-2xl shadow-md transition"
                    >
                        Iniciar sesión
                    </button>
                </form>
            </div>

            <!-- COLUMNA DERECHA -->
            <div class="border-l-0 lg:border-l border-slate-300 lg:pl-8">

            <!-- LOGIN SOCIAL -->

<div class="space-y-4 mb-6">

    <!-- GOOGLE -->
    <a href="/auth/google?rol=<%= rol %>"
    class="w-full flex items-center justify-between bg-white hover:bg-slate-50 border border-slate-200 text-slate-800 rounded-2xl shadow-md px-5 py-5 transition hover:scale-[1.01]">

        <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-slate-100 flex items-center justify-center shrink-0">
                <img
                    src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg"
                    class="w-7 h-7 object-contain"
                    alt="Google"
                >
            </div>

            <div class="text-left">
                <p class="font-bold text-xl leading-none">Google</p>
                <p class="text-sm text-slate-500 mt-1">Acceso con tu cuenta Google</p>
            </div>
        </div>

        <span class="text-xl text-slate-400 shrink-0">→</span>
    </a>

    <!-- FACEBOOK -->
    <a href="/auth/facebook?rol=<%= rol %>"
    class="w-full flex items-center justify-between bg-[#1877F2] hover:bg-[#1669d8] text-white rounded-2xl shadow-md px-5 py-5 transition hover:scale-[1.01]">

        <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-white/20 flex items-center justify-center shrink-0">
                <span class="text-3xl font-bold leading-none text-white">f</span>
            </div>

            <div class="text-left">
                <p class="font-bold text-xl leading-none">Facebook</p>
                <p class="text-sm text-blue-100 mt-1">Acceso con tu cuenta de Facebook</p>
            </div>
        </div>

        <span class="text-xl text-white/80 shrink-0">→</span>
    </a>

</div>        
                <!-- TELEFONO -->
                <form id="phoneLoginForm" class="space-y-5">
                    <div>
                        <label for="telefono" class="block text-sm font-semibold text-slate-700 mb-2">
                            Número telefónico
                        </label>
                        <input
                            type="text"
                            id="telefono"
                            name="telefono"
                            placeholder="Ingresa tu número telefónico"
                            class="w-full rounded-2xl border border-blue-200 bg-slate-50 px-4 py-4 focus:outline-none focus:ring-2 focus:ring-blue-400"
                        >
                    </div>

                    <div>
                        <label for="passwordTelefono" class="block text-sm font-semibold text-slate-700 mb-2">
                            Contraseña
                        </label>
                        <input
                            type="password"
                            id="passwordTelefono"
                            name="password"
                            placeholder="Ingresa tu contraseña"
                            class="w-full rounded-2xl border border-blue-200 bg-slate-50 px-4 py-4 focus:outline-none focus:ring-2 focus:ring-blue-400"
                        >
                    </div>

                    <p id="errorMsgTelefono" class="hidden text-sm font-semibold" style="color:#941F4E;"></p>

                    <button
                        type="submit"
                        class="w-full bg-blue-700 hover:bg-blue-800 text-white font-semibold px-6 py-4 rounded-2xl shadow-md transition"
                    >
                        Iniciar sesión con teléfono
                    </button>
                </form>
            </div>
        </div>

        <!-- PARTE INFERIOR -->
        <div class="grid md:grid-cols-2 gap-6 items-center mt-8">
            <div class="text-center text-sm text-slate-500">
                Al continuar, aceptas nuestros
                <span class="text-blue-700 font-medium">Términos</span>
                y
                <span class="text-blue-700 font-medium">Política de Privacidad</span>.
            </div>

            <div class="text-center md:text-right">
                <a href="/">
                    Volver al inicio
                </a>
            </div>
        </div>
    </div>

    <script>
        // LOGIN POR CORREO
        const emailLoginForm = document.getElementById('emailLoginForm');
        const correoEmail = document.getElementById('correoEmail');
        const passwordEmail = document.getElementById('passwordEmail');
        const errorMsgEmail = document.getElementById('errorMsgEmail');

        emailLoginForm.addEventListener('submit', function(e) {
            e.preventDefault();

            const correoValor = correoEmail.value.trim();
            const passwordValor = passwordEmail.value.trim();

            errorMsgEmail.classList.remove('hidden');

            if (!correoValor || !passwordValor) {
                errorMsgEmail.textContent = 'Por favor, completa todos los campos.';
                return;
            }

            errorMsgEmail.textContent = 'Los datos ingresados no son válidos.';
        });

        // LOGIN POR TELÉFONO
        const phoneLoginForm = document.getElementById('phoneLoginForm');
        const telefono = document.getElementById('telefono');
        const passwordTelefono = document.getElementById('passwordTelefono');
        const errorMsgTelefono = document.getElementById('errorMsgTelefono');

        phoneLoginForm.addEventListener('submit', function(e) {
            e.preventDefault();

            const telefonoValor = telefono.value.trim();
            const passwordValor = passwordTelefono.value.trim();

            errorMsgTelefono.classList.remove('hidden');

            if (!telefonoValor || !passwordValor) {
                errorMsgTelefono.textContent = 'Por favor, completa todos los campos.';
                return;
            }

            const telefonoLimpio = telefonoValor.replace(/\s+/g, '');

            if (!/^\d{10}$/.test(telefonoLimpio)) {
                errorMsgTelefono.textContent = 'Ingresa un número telefónico válido de 10 dígitos.';
                return;
            }

            errorMsgTelefono.textContent = 'Los datos ingresados no son válidos.';
        });
    </script>

</body>
</html>